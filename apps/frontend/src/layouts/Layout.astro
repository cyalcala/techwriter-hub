---
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-oat-50 text-blueberry-900 scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="selection:bg-blueberry-100 selection:text-blueberry-900 font-['Geist',sans-serif] bg-oat-50 antialiased overflow-x-hidden min-h-screen">
		<Navbar />
		<div class="relative pt-20">
			<slot />
		</div>

		<script is:inline>
			// ATOMIC INTERACTION ENGINE V2 (VA.INDEX)
			(function() {
				const state = { query: "", ageLimit: 'all', activeOnly: false };

				function syncUI() {
					const path = window.location.pathname;
					const searchInput = document.getElementById('oppSearch') || document.getElementById('agencySearch');
					if (searchInput) searchInput.value = state.query;

					// 1. Sync Feed
					const fGrid = document.getElementById('oppsGrid');
					if (fGrid) {
						fGrid.dataset.filterAge = state.ageLimit;
						const items = fGrid.querySelectorAll('.opp-item');
						let visible = 0;
						items.forEach(item => {
							const text = item.getAttribute('data-search') || '';
							const age = parseFloat(item.getAttribute('data-age') || '999');
							const ageMatch = state.ageLimit === 'all' || age <= parseFloat(state.ageLimit);
							const show = text.includes(state.query) && ageMatch;
							item.classList.toggle('hidden-by-search', !show);
							if (show) visible++;
						});
						const fEmpty = document.getElementById('oppsEmpty');
						if (fEmpty) fEmpty.style.display = visible > 0 ? 'none' : 'block';
					}

					// 2. Sync Agencies
					const aGrid = document.getElementById('agenciesGrid');
					if (aGrid) {
						aGrid.dataset.filterActive = state.activeOnly;
						const cards = aGrid.querySelectorAll('.glass-card');
						let visible = 0;
						cards.forEach(card => {
							const name = card.getAttribute('data-name') || '';
							const status = card.getAttribute('data-status');
							const statusMatch = !state.activeOnly || status === 'active';
							const show = name.includes(state.query) && statusMatch;
							card.classList.toggle('hidden-by-search', !show);
							if (show) visible++;
						});
						const aEmpty = document.getElementById('agenciesEmpty');
						if (aEmpty) aEmpty.style.display = visible > 0 ? 'none' : 'block';
					}
				}

				document.addEventListener('input', (e) => {
					if (e.target.id === 'oppSearch' || e.target.id === 'agencySearch') {
						state.query = e.target.value.toLowerCase().trim();
						syncUI();
					}
				});

				document.addEventListener('click', (e) => {
					const ageBtn = e.target.closest('[data-age-filter]');
					if (ageBtn) {
						const container = ageBtn.closest('#timeFilters');
						container.querySelectorAll('.time-btn').forEach(b => b.classList.remove('active'));
						ageBtn.classList.add('active');
						state.ageLimit = ageBtn.getAttribute('data-age-filter');
						syncUI();
					}

					const hireBtn = e.target.closest('[data-toggle-hiring]');
					if (hireBtn) {
						state.activeOnly = !state.activeOnly;
						hireBtn.classList.toggle('active-filter', state.activeOnly);
						hireBtn.innerText = state.activeOnly ? '✓ Showing Hiring' : 'Hiring Now Only';
						syncUI();
					}
				});

				document.addEventListener('astro:page-load', () => {
					syncUI();
				});
				
				syncUI();
			})();
		</script>

		<style is:global>
			/* Zero-Blink CSS Filter System */
			.hidden-by-search { display: none !important; }

			/* Feed Age Filtering */
			#oppsGrid[data-filter-age="24"] .opp-item { display: none; }
			#oppsGrid[data-filter-age="24"] .opp-item[data-age] { 
				display: flex; /* overridden by specific age */
			}
			/* This is complex in CSS, so we'll stick to a hybrid: 
			   discrete categories are easy, numeric comparisons are hard.
			   Since we only have 24 and 72, I'll keep the JS toggle 
			   but optimize it to be flicker-free via classes. */

			/* Agencies Status Filtering (This is 100% CSS) */
			#agenciesGrid[data-filter-active="true"] .glass-card[data-status="quiet"] {
				display: none !important;
			}

			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: #FDFBF7;
			}
			::-webkit-scrollbar-thumb {
				background: #C5CAE9;
				border: 2px solid #FDFBF7;
				border-radius: 10px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: #5C6BC0;
			}
		</style>
	</body>
</html>
