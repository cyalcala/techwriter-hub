---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import SignalCard from '../../components/SignalCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

import { getSortedSignals } from '@va-hub/db/sorting';
import { JobDomain, DOMAIN_MANIFEST, getDomainBySlug, getDomainLabel } from '@va-hub/db/taxonomy';

const { slug } = Astro.params;
const domain = getDomainBySlug(slug || '');

if (!domain) {
  return Astro.redirect('/404');
}

const manifest = DOMAIN_MANIFEST.find(d => d.domain === domain);
let signals = [];

try {
  if (process.env.TURSO_DATABASE_URL) {
    const allSignals = await getSortedSignals(1000);
    signals = allSignals.filter(sig => sig.niche === domain);
  } else {
    throw new Error("Edge Configuration Missing");
  }
} catch (err: any) {
  console.error(`[SRE_CUSTODY] CRITICAL: Sector Data Fetch Failure: ${err.message}`);
  throw new Error(`[SRE_CUSTODY] DATABASE_CUSTODY_LOST: ${err.message}.`);
}
---

<Layout title={`${getDomainLabel(domain)} | VA.INDEX`}>
  <main class="max-w-[1200px] mx-auto px-6 py-10">
    <Breadcrumbs domain={getDomainLabel(domain)} />

    <header class="mb-12 mt-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-10">
        <div class="flex items-center gap-6">
          <div class="w-20 h-20 rounded-[2.5rem] bg-white shadow-xl border border-oat-200/50 flex items-center justify-center text-5xl shrink-0 group-hover:scale-110 transition-transform duration-500">
            {manifest?.symbol || "🌐"}
          </div>
          <div>
            <h1 class="text-5xl sm:text-6xl font-black text-blueberry-900 uppercase tracking-tighter leading-[0.85] mb-3">
              {getDomainLabel(domain)}
            </h1>
            <p class="text-xl text-blueberry-800/50 font-medium max-w-2xl leading-relaxed">
              {manifest?.description}
            </p>
          </div>
        </div>

        <div class="relative w-full md:w-80 group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-blueberry-800/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="domainSearch" 
            placeholder={`Search ${getDomainLabel(domain)}...`} 
            class="bg-white border-2 border-oat-200/50 rounded-2xl pl-12 pr-4 py-4 text-sm text-blueberry-900 focus:outline-none focus:border-blueberry-900/20 transition-all font-bold w-full shadow-lg placeholder:text-blueberry-800/20"
          />
        </div>
      </div>

      <div class="flex items-center gap-3">
        <div class="px-5 py-2.5 bg-white border border-oat-200 rounded-2xl flex items-center gap-3 shadow-sm">
          <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="text-[10px] font-black text-blueberry-900 uppercase tracking-[0.2em]" id="signalCount">
            {signals.length} Live Signals Detected
          </span>
        </div>
      </div>
    </header>

    <div class="flex flex-col gap-3" id="signalList">
      {signals.map((sig, idx) => (
        <div class="domain-item transition-all duration-300" data-search={`${sig.title} ${sig.company} ${sig.tags}`.toLowerCase()}>
          <SignalCard signal={sig} index={idx + 1} />
        </div>
      ))}
    </div>

    <div id="noResults" class="hidden py-40 text-center border-2 border-dashed border-oat-200 rounded-[3rem] bg-oat-50/20">
      <span class="text-blueberry-800/20 font-black uppercase tracking-[0.3em] text-xs italic block mb-2">No matches in this domain.</span>
      <span class="text-[10px] text-blueberry-800/10 font-bold uppercase tracking-widest">Try a different keyword or check the global directory</span>
    </div>

    {signals.length === 0 && (
      <div class="py-40 text-center border-2 border-dashed border-oat-200 rounded-3xl bg-oat-50/30">
        <span class="text-blueberry-800/20 font-black uppercase tracking-[0.3em] text-xs italic">
          No active signals found in this domain.
        </span>
      </div>
    )}
  </main>
</Layout>

<script is:inline>
  function initDomainSearch() {
    const search = document.getElementById('domainSearch');
    const list = document.getElementById('signalList');
    const count = document.getElementById('signalCount');
    const empty = document.getElementById('noResults');
    if (!search || !list) return;

    const items = Array.from(list.querySelectorAll('.domain-item'));

    search.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      let visibleCount = 0;

      items.forEach(item => {
        const text = item.dataset.search;
        const isMatch = text.includes(q);
        
        if (isMatch) {
          item.style.display = 'block';
          item.style.opacity = '1';
          visibleCount++;
        } else {
          item.style.display = 'none';
          item.style.opacity = '0';
        }
      });

      if (count) count.textContent = `${visibleCount} Signals Matching "${q}"`;
      if (empty) {
        if (visibleCount === 0 && q.length > 0) empty.classList.remove('hidden');
        else empty.classList.add('hidden');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initDomainSearch);
  document.addEventListener('astro:after-swap', initDomainSearch);
  initDomainSearch();
</script>
