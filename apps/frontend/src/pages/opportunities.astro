---
import Layout from '../layouts/Layout.astro';
import { db } from '@va-hub/db/client';
import { opportunities as opportunitiesTable } from '@va-hub/db/schema';
import { desc } from 'drizzle-orm';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'max-age=0, s-maxage=60, stale-while-revalidate=59');

let liveOpportunities = [];
let dbError = null;

try {
  liveOpportunities = await db.select()
    .from(opportunitiesTable)
    .orderBy(desc(opportunitiesTable.scrapedAt))
    .limit(500); // 500 is a safe middle ground
} catch (e) {
  dbError = e.message;
}

function formatRelativeTime(dateInput: Date | null) {
  if (!dateInput) return 'Today';
  const now = new Date();
  const date = new Date(dateInput);
  const diffHours = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60));
  if (diffHours <= 4) return 'Just Now';
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays === 1) return '1d ago';
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

function getRelevanceMetadata(opp: any) {
  const text = `${opp.title} ${opp.company} ${opp.description || ''}`.toLowerCase();
  
  const isVaFriendly = ["assistant", "va", "customer", "support", "admin", "bookkeeping", "filipino", "philippines", "pinoy"].some(k => text.includes(k));
  const isTech = ["engineer", "developer", "devops", "software", "backend", "frontend", "architect"].some(k => text.includes(k));
  const isSenior = ["senior", "vp", "director", "lead", "principal", "head"].some(k => text.includes(k));

  let score = 0;
  if (isVaFriendly) score += 50000;
  if (isSenior) score -= 20000;
  if (isTech && !isVaFriendly) score -= 10000;
  
  // Recency Boost
  const now = Date.now();
  const scrapedAt = new Date(opp.scrapedAt).getTime();
  const discoveryHours = (now - scrapedAt) / (1000 * 60 * 60);
  if (discoveryHours <= 12) score += 100000; // HUGE boost for today's discoveries

  return { score, isVaFriendly, isTech };
}

const scored = liveOpportunities.map(opp => {
  const meta = getRelevanceMetadata(opp);
  return { ...opp, relevancyScore: meta.score, isVaFriendly: meta.isVaFriendly };
}).sort((a, b) => (b.relevancyScore - a.relevancyScore));

// Diversity Logic
const companyCount = new Map();
const topTier = [];
const bottomTier = [];

for (const opp of scored) {
  const company = (opp.company || 'Unknown').toLowerCase().trim();
  const count = companyCount.get(company) || 0;
  const limit = opp.isVaFriendly ? 3 : 1;
  
  if (count < limit) {
    topTier.push(opp);
    companyCount.set(company, count + 1);
  } else {
    bottomTier.push(opp);
  }
}

const opportunities = [...topTier, ...bottomTier].slice(0, 150).map(opp => {
  const latestDate = new Date(Math.max(new Date(opp.postedAt || 0).getTime(), new Date(opp.scrapedAt).getTime()));
  const ageHours = (Date.now() - latestDate.getTime()) / (1000 * 60 * 60);

  return {
    ...opp,
    dateLabel: formatRelativeTime(latestDate),
    ageHours
  };
});
---

<Layout title="Opportunities | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        <div class="pulse-dot"></div>
        <span class="text-[10px] font-black text-blueberry-500 tracking-[0.2em] uppercase">SYSTEM_LIVE</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-blueberry-900 tracking-tighter mb-4">Latest Roles</h1>
      <div class="flex items-center gap-4 mt-6">
        <input 
          type="text" 
          id="oppSearch" 
          placeholder="Filter by title or company..." 
          class="bg-white border border-blueberry-800/10 rounded-2xl px-6 py-3 text-sm focus:outline-none focus:border-blueberry-500/40 w-full max-w-md"
        />
        <div class="flex p-1 bg-white border border-blueberry-800/10 rounded-2xl shadow-sm" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <div class="flex flex-col gap-2" id="oppsGrid">
      {opportunities.map((opp) => (
        <a 
          href={opp.sourceUrl} 
          target="_blank" 
          class="opp-item flex items-center justify-between p-4 rounded-2xl bg-white border border-blueberry-800/10 hover:border-blueberry-500/30 transition-all group"
          data-search={`${opp.title} ${opp.company}`.toLowerCase()}
          data-age={opp.ageHours}
        >
          <div class="flex items-center gap-6">
            <div class="w-14 text-center">
              <span class="text-[10px] font-mono text-blueberry-800/40 font-black">{opp.dateLabel}</span>
              {opp.ageHours <= 24 && <div class="text-[7px] text-emerald-600 font-black uppercase mt-1">Hot</div>}
            </div>
            <div>
              <div class="text-[11px] font-black text-blueberry-900 uppercase tracking-tight">{opp.title}</div>
              <div class="text-[9px] text-blueberry-800/60 font-bold uppercase tracking-widest">{opp.company}</div>
            </div>
          </div>
          <div class="text-[9px] font-black text-blueberry-800/30 uppercase tracking-widest group-hover:text-blueberry-600 transition-colors">
            {opp.sourcePlatform} ↗
          </div>
        </a>
      ))}
    </div>

    <div id="emptyState" class="hidden py-24 text-center text-blueberry-800/40 text-sm italic">
      No roles match your current filter.
    </div>
  </main>
</Layout>

<script is:inline>
  function setupFeed() {
    console.log("[Feed] SYNC_INTERACTION_LAYER");
    setTimeout(() => {
      const search = document.getElementById('oppSearch');
      const filters = document.getElementById('timeFilters');
      const grid = document.getElementById('oppsGrid');
      const empty = document.getElementById('emptyState');
      
      if (!search || !filters || !grid) {
        console.warn("[Feed] Elements missing, retrying...");
        return;
      }

      const items = grid.querySelectorAll('.opp-item');
      const btns = filters.querySelectorAll('.time-btn');
      let ageLimit = Infinity;

      function refresh() {
        const q = search.value.toLowerCase();
        let visible = 0;
        items.forEach(item => {
          const text = item.getAttribute('data-search') || '';
          const age = parseFloat(item.getAttribute('data-age') || '999');
          const show = text.includes(q) && age <= ageLimit;
          item.style.display = show ? 'flex' : 'none';
          if (show) visible++;
        });
        if (empty) empty.style.display = visible > 0 ? 'none' : 'block';
      }

      search.oninput = refresh;
      
      btns.forEach(btn => {
        btn.onclick = (e) => {
          e.preventDefault();
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const f = btn.getAttribute('data-filter');
          ageLimit = (f === 'all') ? Infinity : parseFloat(f);
          refresh();
        };
      });
      console.log(`[Feed] BINDING_SUCCESS: ${items.length} items bound.`);
    }, 50);
  }

  setupFeed();
  document.addEventListener('astro:page-load', setupFeed);
  document.addEventListener('astro:after-swap', setupFeed);
</script>

<style>
  .time-btn {
    @apply px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer;
    @apply text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-blueberry-50 text-blueberry-900 border border-blueberry-800/10;
  }
</style>
