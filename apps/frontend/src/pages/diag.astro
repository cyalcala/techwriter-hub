---
export const prerender = false;
const { env } = Astro.locals.runtime || { env: {} };

const dbStatus = env.DB ? "CONNECTED" : "MISSING";
const kvStatus = env.BODEGA ? "CONNECTED" : "MISSING";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>TechWriter Hub | Diagnostics</title>
	</head>
	<body style="font-family: sans-serif; padding: 40px; text-align: center;">
    <h1 style="text-transform: uppercase;">TechWriter Hub</h1>
    <p>Diagnostic Mode: Zero-Import Isolation</p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px;">
      <div style="padding: 20px; border: 1px solid #eee; border-radius: 20px;">
        <div style="font-size: 10px; color: #999;">D1 Database</div>
        <div style="font-weight: bold;">{dbStatus}</div>
      </div>
      <div style="padding: 20px; border: 1px solid #eee; border-radius: 20px;">
        <div style="font-size: 10px; color: #999;">Bodega KV</div>
        <div style="font-weight: bold;">{kvStatus}</div>
      </div>
    </div>

    <div style="margin-top: 40px; padding: 20px; background: #000; color: #0f0; border-radius: 20px; text-align: left; font-family: monospace; font-size: 12px;">
      SSR ADAPTER: NOMINAL<br/>
      RUNTIME: CLOUDFLARE_PAGES<br/>
      TIMESTAMP: {new Date().toISOString()}
    </div>
	</body>
</html>
