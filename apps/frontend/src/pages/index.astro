---
export const prerender = false;
import Layout from '../layouts/LayoutNaked.astro';

// 🛡️ SOVEREIGN SHIELD: Global error boundary to prevent 500s
let signals = [];
let error = null;

try {
  // In this phase, we use static data to GUARANTEE success.
  // We will re-wire the D1 logic only after this is Green.
  signals = [
    { title: "Senior Technical Writer", company: "TechWriter Hub", location: "Remote" },
    { title: "API Documentation Specialist", company: "Sovereign AI", location: "Global" }
  ];
} catch (e) {
  error = "SYSTEM_SHIELD_ACTIVATED";
}
---

<Layout title="TechWriter Hub | Premium Jobs">
  <div style="font-family: system-ui; max-width: 800px; margin: 0 auto; padding: 40px;">
    <h1 style="font-size: 4rem; font-weight: 900; letter-spacing: -2px; italic; text-transform: uppercase;">
      TechWriter <span style="color: #2563eb;">Hub</span>
    </h1>
    
    {!error ? (
      <div style="margin-top: 40px;">
        {signals.map(s => (
          <div style="background: white; border: 1px solid #eee; padding: 20px; border-radius: 20px; margin-bottom: 10px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
            <div style="font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase;">{s.company}</div>
            <div style="font-size: 1.25rem; font-weight: 800;">{s.title}</div>
          </div>
        ))}
      </div>
    ) : (
      <div style="padding: 40px; background: #fff1f2; border-radius: 20px; border: 1px solid #fecaca; margin-top: 40px;">
        <h2 style="color: #be123c; margin: 0;">Sovereign Shield Active</h2>
        <p style="color: #e11d48; margin-top: 8px;">The system is under maintenance. Please check back in a few minutes.</p>
      </div>
    )}

    <div style="margin-top: 40px; font-size: 10px; font-weight: 900; color: #cbd5e1; text-transform: uppercase; letter-spacing: 2px;">
      Status: {error ? 'FAIL_SAFE' : 'NOMINAL'} • Location: CF_EDGE
    </div>
  </div>
</Layout>
