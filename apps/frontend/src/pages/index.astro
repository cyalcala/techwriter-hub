---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import SignalCard from '../components/SignalCard.astro';
import { createDb } from '../lib/db/client';
import { opportunities } from '../lib/db/schema';
import { desc, eq } from 'drizzle-orm';

// 📡 SOVEREIGN DATA FETCH
const { env } = Astro.locals.runtime || { env: {} };
let signals = [];
let pulseStatus = "SYSTEM NOMINAL";
let lastPulse = "Just now";

if (!env.DB || !env.BODEGA) {
  console.error("❌ CRITICAL: Cloudflare Bindings (DB/BODEGA) are missing from the environment.");
  pulseStatus = "BONDING ERROR";
} else {
  const { db } = createDb(env.DB);
  
  if (!db) {
    pulseStatus = "DB INIT ERROR";
  } else {
    try {
      // 🍽️ PLATE: Fetch minimal active TechWriter jobs
      signals = await db.select({
        id: opportunities.id,
        title: opportunities.title,
        company: opportunities.company,
        url: opportunities.url,
        salary: opportunities.salary,
        type: opportunities.type,
        tags: opportunities.tags,
        locationType: opportunities.locationType,
        postedAt: opportunities.postedAt,
        latestActivityMs: opportunities.latestActivityMs
      })
        .from(opportunities)
        .where(eq(opportunities.isActive, true))
        .orderBy(desc(opportunities.latestActivityMs))
        .limit(50);

      // 🏺 BODEGA: Check heartbeat
      const lastHarvest = await env.BODEGA.get("pulse:last_harvest");
      if (lastHarvest) {
        const diff = Date.now() - parseInt(lastHarvest);
        if (diff > 3600000) pulseStatus = "PULSE STALE";
        lastPulse = new Intl.RelativeTimeFormat('en', { style: 'short' }).format(-Math.round(diff / 60000), 'minutes');
      }
    } catch (err) {
      console.error("Failed to load TechWriter signals:", err);
      pulseStatus = "FETCH ERROR";
    }
  }
}
---

<html>
  <body style="font-family: monospace; padding: 20px; background: #f8fafc;">
    <h1>DATA_LAYER_VERIFICATION</h1>
    <p>Status: {pulseStatus}</p>
    <p>Last Pulse: {lastPulse}</p>
    <hr/>
    <pre>
      {JSON.stringify(signals, null, 2)}
    </pre>
  </body>
</html>
