---
// 🚀 CONVERTED TO STATIC (SSG) FOR ZERO-CRASH RELIABILITY
import Layout from '../layouts/LayoutNaked.astro';

// We use static mock data for the first static build to ENSURE it loads.
// Once this is green, we can re-enable the dynamic fetch if desired.
const signals = [
  {
    id: "1",
    title: "Senior Technical Writer",
    company: "TechWriter Hub Global",
    locationType: "Remote",
    type: "Full-time",
    postedAt: "Just now",
    tags: ["Documentation", "API"]
  },
  {
    id: "2",
    title: "Technical Editor (Contract)",
    company: "Sovereign Systems",
    locationType: "Remote",
    type: "Contract",
    postedAt: "1 hour ago",
    tags: ["Editing", "QA"]
  }
];
---

<Layout title="TechWriter Hub | Premium Technical Writing Jobs">
  <style>
    :root { --color-primary: #2563eb; }
    body { background: #f8fafc; font-family: system-ui, -apple-system, sans-serif; color: #1e293b; margin: 0; }
    .hub-header { text-align: center; padding: 80px 20px; }
    .hub-title { font-size: 4rem; font-weight: 900; letter-spacing: -2px; text-transform: uppercase; font-style: italic; margin: 0; }
    .hub-accent { color: var(--color-primary); }
    .hub-container { max-width: 800px; mx-auto; margin: 0 auto; padding: 20px; }
    .card { background: white; border-radius: 24px; padding: 24px; margin-bottom: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); display: flex; justify-content: space-between; align-items: center; }
    .tag { background: #eff6ff; color: #2563eb; font-size: 10px; font-weight: 800; padding: 4px 8px; rounded-radius: 6px; text-transform: uppercase; margin-right: 4px; border-radius: 4px; }
  </style>

  <div class="hub-header">
    <h1 class="hub-title">TechWriter <span class="hub-accent">Hub</span></h1>
    <p style="font-weight: 500; color: #64748b; font-size: 1.25rem;">The Gold Standard for Technical Writing Jobs.</p>
  </div>

  <div class="hub-container">
    <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
       <span style="font-size: 10px; font-weight: 900; color: #94a3b8; text-transform: uppercase; letter-spacing: 2px;">Live Signals</span>
       <div style="display: flex; items-center; gap: 8px;">
         <div style="width: 8px; height: 8px; background: #10b981; border-radius: 50%;"></div>
         <span style="font-size: 10px; font-weight: 900; color: #10b981; text-transform: uppercase;">System Online</span>
       </div>
    </div>

    {signals.map(sig => (
      <div class="card">
        <div>
          <div style="font-size: 11px; font-weight: 800; color: #94a3b8; text-transform: uppercase; margin-bottom: 4px;">{sig.company}</div>
          <div style="font-size: 1.25rem; font-weight: 800; color: #0f172a; margin-bottom: 8px;">{sig.title}</div>
          <div>
            {sig.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 12px; font-weight: 700; color: #475569;">{sig.locationType}</div>
          <div style="font-size: 10px; font-weight: 600; color: #94a3b8;">{sig.postedAt}</div>
        </div>
      </div>
    ))}

    <div style="margin-top: 40px; text-align: center; color: #94a3b8; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
      MADE WITH ❤️ BY CY ALCALA
    </div>
  </div>
</Layout>
