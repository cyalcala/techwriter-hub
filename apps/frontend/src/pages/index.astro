---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import SignalCard from '../components/SignalCard.astro';
import MirrorStage from '../components/MirrorStage.astro';

// Use direct relative imports to bypass workspace alias issues if needed
import { getSortedSignals, getLatestMirror } from '../../../../packages/db/sorting';
import { db, schema } from '../../../../packages/db/client';
import { sql, eq } from 'drizzle-orm';
import staticFallback from '../data/static_fallback.json';

// Variables initialization
let initialSignals = [];
let mirrorSignals = [];
let healthStats = { status: 'STANDBY', lastHeartbeat: null };
let dbError = null;

try {
  if (process.env.TURSO_DATABASE_URL) {
    initialSignals = await getSortedSignals(50);
    mirrorSignals = await getLatestMirror(10);
    
    // Quick Health Pulse
    const stats = await db.select({
      maxScraped: sql<number>`max(scraped_at)`,
    }).from(schema.opportunities).where(eq(schema.opportunities.isActive, true));
    
    if (stats[0]?.maxScraped) {
      healthStats = { 
        status: 'ACTIVE', 
        lastHeartbeat: new Date(stats[0].maxScraped).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) 
      };
    }
  }
} catch (err: any) {
  console.warn("⚠️ Fail-Soft Active:", err.message);
  initialSignals = staticFallback;
  mirrorSignals = staticFallback.slice(0, 10);
  dbError = 'OFFLINE';
}
---

<Layout title="Live Feed | VA.INDEX">
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <header class="mb-16">
      <div class="flex items-center gap-6 mb-8 group cursor-default">
        <div class="flex items-center gap-2">
          <div class="pulse-dot"></div>
          <span class="text-[10px] font-black text-blueberry-500 tracking-[0.3em] uppercase transition-all group-hover:tracking-[0.5em]">LIVE SIGNALS</span>
        </div>
        
        <div class="h-4 w-[1px] bg-oat-200"></div>

        <div class="flex items-center gap-2 px-3 py-1 bg-white/50 border border-oat-200/50 rounded-full shadow-sm backdrop-blur-sm">
          <span class="text-[9px] font-black text-blueberry-800/40 uppercase tracking-tighter">System Pulse:</span>
          <span class="text-[10px] font-black text-emerald-600 uppercase">
            {healthStats.status}
          </span>
          {healthStats.lastHeartbeat && (
            <span class="text-[9px] font-bold text-blueberry-800/30">
              Synced {healthStats.lastHeartbeat}
            </span>
          )}
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-12">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-6xl font-black text-blueberry-900 mb-6 leading-[0.9] tracking-tighter uppercase whitespace-pre-line font-heading transition-all hover:tracking-tight">
            Live Signals. Automated Capture. 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Your Next Job, Found.</span>
          </h1>
          <p class="text-lg text-blueberry-800/70 font-medium leading-relaxed max-w-xl">
             Indestructible harvesting of high-intent remote roles. We surgically prioritize Filipino-accessible VA and non-tech opportunities by purging global noise at the edge.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative w-full sm:max-w-md group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none transition-colors group-focus-within:text-emerald-500 text-blueberry-800/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </div>
          <input 
            type="text" 
            id="oppSearch" 
            placeholder="Sift through signals..." 
            class="bg-white border-2 border-oat-200/50 rounded-2xl pl-12 pr-6 py-4 text-sm text-blueberry-900 focus:outline-none focus:border-blueberry-900/10 focus:ring-4 focus:ring-blueberry-500/5 transition-all font-medium placeholder:text-blueberry-800/30 w-full shadow-sm"
          />
        </div>
        <div class="flex items-center gap-1.5 p-1 bg-oat-100/50 border border-oat-200/50 rounded-2xl shadow-inner overflow-hidden shrink-0" id="timeFilters">
          <button data-filter="all" class="time-btn active">All</button>
          <button data-filter="24" class="time-btn text-emerald-600">24h</button>
          <button data-filter="72" class="time-btn">3d</button>
        </div>
      </div>
    </header>

    <MirrorStage signals={mirrorSignals.length > 0 ? mirrorSignals : initialSignals.slice(0, 10)} />

    <div class="grid grid-cols-1 gap-3" id="oppsGrid">
      {initialSignals.map((sig) => (
        <SignalCard signal={sig} />
      ))}
    </div>

    <div id="emptyState" class="hidden py-40 text-center text-blueberry-800/30 font-black uppercase tracking-widest text-sm italic">
      No matching signals found.
    </div>
  </main>
</Layout>

<script is:inline>
  function initFeed() {
    const search = document.getElementById('oppSearch');
    const filters = document.getElementById('timeFilters');
    const grid = document.getElementById('oppsGrid');
    const empty = document.getElementById('emptyState');
    if (!grid) return;

    let items = Array.from(grid.querySelectorAll('.opp-item')).map(el => ({
      el,
      text: el.dataset.search || "",
      age: parseFloat(el.dataset.age || "999")
    }));

    const btns = filters?.querySelectorAll('.time-btn');
    let q = "";
    let limit = Infinity;
    let debounceTimer;

    function run() {
      let count = 0;
      for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const match = item.text.includes(q) && item.age <= limit;
        item.el.style.display = match ? 'flex' : 'none';
        if (match) count++;
      }
      if (empty) empty.style.display = count > 0 ? 'none' : 'block';
    }

    if (search) {
      search.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          q = e.target.value.toLowerCase().trim();
          run();
        }, 50); 
      });
    }

    if (btns) {
      btns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const val = btn.dataset.filter;
          limit = val === 'all' ? Infinity : parseFloat(val);
          run();
        });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initFeed);
  // Re-init for View Transitions
  document.addEventListener('astro:after-swap', initFeed);
  initFeed();
</script>

<style>
  .time-btn {
    @apply px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all cursor-pointer text-blueberry-800/40 hover:text-blueberry-900;
  }
  .time-btn.active {
    @apply bg-white text-blueberry-900 shadow-sm border border-black/5;
  }
</style>
