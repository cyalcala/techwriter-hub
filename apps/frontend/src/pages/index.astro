---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import SignalCard from '../components/SignalCard.astro';
import { createDb } from '@va-hub/db/client';
import { opportunities } from '@va-hub/db/schema';
import { desc, eq } from 'drizzle-orm';

// 📡 SOVEREIGN DATA FETCH
const { env } = Astro.locals.runtime;
const { db } = createDb(env.DB);

let signals = [];
let pulseStatus = "SYSTEM NOMINAL";
let lastPulse = "Just now";

try {
  // 🍽️ PLATE: Fetch all active TechWriter jobs
  signals = await db.select()
    .from(opportunities)
    .where(eq(opportunities.isActive, true))
    .orderBy(desc(opportunities.latestActivityMs))
    .limit(100);

  // 🏺 BODEGA: Check heartbeat
  const lastHarvest = await env.BODEGA.get("pulse:last_harvest");
  if (lastHarvest) {
    const diff = Date.now() - parseInt(lastHarvest);
    if (diff > 3600000) pulseStatus = "PULSE STALE";
    lastPulse = new Intl.RelativeTimeFormat('en', { style: 'short' }).format(-Math.round(diff / 60000), 'minutes');
  }
} catch (err) {
  console.error("Failed to load TechWriter signals:", err);
}

---

<Layout title="TechWriter Hub | Global Technical Writing Jobs for Filipinos">
  <main class="max-w-[1000px] mx-auto px-4 py-16">
    <header class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full shadow-sm mb-6">
        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest leading-none">
          {pulseStatus} • {lastPulse}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-4 tracking-tighter uppercase italic">
        TechWriter <span class="text-blue-600">Hub</span>
      </h1>
      <p class="text-xl text-slate-500 font-medium max-w-2xl mx-auto">
        Only high-fidelity Technical Writing jobs worldwide for Filipinos. <br/>
        Zero noise. Zero staleness.
      </p>
    </header>

    <div class="bg-white rounded-[2.5rem] p-4 md:p-8 shadow-2xl border border-slate-100">
      <div class="flex items-center justify-between mb-8 px-4">
        <h2 class="text-sm font-black text-slate-400 uppercase tracking-widest">
          Live Opportunity Feed
        </h2>
        <span class="text-[11px] font-bold text-slate-300">
          Showing {signals.length} Active Signals
        </span>
      </div>

      <div class="space-y-2">
        {signals.map((sig) => (
          <SignalCard signal={sig} />
        ))}
        
        {signals.length === 0 && (
          <div class="py-20 text-center border-2 border-dashed border-slate-100 rounded-3xl">
             <p class="text-slate-300 font-bold uppercase tracking-widest text-sm">
               Establishing Pulse... No signals detected yet.
             </p>
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>
