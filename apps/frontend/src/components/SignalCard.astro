---
import { normalizeDate } from '@va-hub/db';
const { signal } = Astro.props;

// Defensive Tags Parsing
const rawTags = signal.tags || [];
const tags = (typeof rawTags === 'string' ? JSON.parse(rawTags) : rawTags) as string[];

const getFavicon = (url: string) => {
  try {
    const u = new URL(url);
    // Use DuckDuckGo favicon service for cleaner results or Google as fallback
    return `https://www.google.com/s2/favicons?domain=${u.hostname}&sz=32`;
  } catch {
    return '';
  }
};

const favicon = getFavicon(signal.url);
---

<li class="relative overflow-hidden group/item list-item ml-4">
  <div class="inline-flex items-center gap-2 pl-2 flex-1 w-full align-middle pt-1 pb-1">
    <!-- Favicon -->
    <div class="w-4 h-4 rounded-sm bg-white flex items-center justify-center overflow-hidden shrink-0 border border-blueberry-900/5">
      {favicon ? (
        <img src={favicon} alt="" class="w-full h-full object-contain" loading="lazy" />
      ) : (
        <div class="w-full h-full bg-blueberry-100 flex items-center justify-center text-[6px] font-bold">
          {signal.company.charAt(0)}
        </div>
      )}
    </div>
    
    <!-- Title Area -->
    <a 
      href={signal.url} 
      target="_blank" 
      class="text-blueberry-900 hover:text-blue-600 font-bold flex items-center gap-2 flex-1 min-w-0 text-[13px] tracking-tight relative"
    >
      <!-- Stretched link for full-row clickability within the LI content area -->
      <span class="absolute inset-0 z-10"></span>
      
      <span class="truncate block max-w-[60%] shrink-0 transition-colors">
        {signal.title}
      </span>

      <!-- Inline Tags -->
      <div class="flex gap-1 overflow-hidden pointer-events-none relative z-20">
        {tags.slice(0, 2).map((tag) => (
          <span class="inline-flex whitespace-nowrap px-1.5 py-0.5 rounded text-[8px] font-extrabold tracking-wider border border-blueberry-900/10 uppercase bg-oat-100/50 text-blueberry-800/60 transition-all group-hover/item:border-blueberry-900/20">
            {tag}
          </span>
        ))}
        {signal.salary && (
           <span class="inline-flex whitespace-nowrap px-1.5 py-0.5 rounded text-[8px] font-extrabold tracking-wider border border-emerald-200 uppercase bg-emerald-50 text-emerald-700">
             💰 {signal.salary}
           </span>
        )}
      </div>
    </a>
  </div>
</li>

<style>
  li::marker {
    @apply text-blueberry-900/30 font-bold text-[12px];
  }
  .list-item {
    content-visibility: auto;
    contain-intrinsic-size: 32px;
  }
</style>
