---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const isAgencies = currentPath === '/agencies';
const isAbout = currentPath === '/about';
---
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-blueberry-800/10 bg-white/70 backdrop-blur-2xl">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 text-blueberry-900 font-black text-sm tracking-tighter hover:scale-105 transition-all font-heading">
      <div class="w-8 h-8 bg-blueberry-900 rounded-xl flex items-center justify-center font-black text-white text-lg shadow-[0_0_20px_-5px_rgba(30,58,138,0.4)]">V</div>
      <div class="flex flex-col leading-none">
        <span class="text-xs tracking-[0.2em]">VA.INDEX</span>
        <span class="text-[8px] text-blueberry-400 tracking-[0.3em] mt-0.5">V6.0 TITANIUM</span>
      </div>
    </a>

    <div class="p-1 bg-oat-100/50 border border-oat-200/50 rounded-2xl flex items-center gap-1 shadow-inner relative overflow-hidden" transition:name="navbar-tabs">
      <div 
        class={`absolute inset-y-1 rounded-xl bg-white shadow-sm border border-blueberry-800/5 transition-all duration-300 ease-out ${isHome ? 'left-1 w-[calc(50%-4px)]' : 'left-[calc(50%+1px)] w-[calc(50%-4px)]'}`}
        transition:name="active-pill"
      ></div>
      <a 
        href="/" 
        class={`relative z-10 px-8 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isHome ? 'text-blueberry-900' : 'text-blueberry-800/40 hover:text-blueberry-900'}`}
      >
        Feed
      </a>
      <a 
        href="/agencies" 
        class={`relative z-10 px-8 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 w-1/2 text-center ${isAgencies ? 'text-blueberry-900' : 'text-blueberry-800/40 hover:text-blueberry-900'}`}
      >
        Sift
      </a>
    </div>
    
    <div class="flex items-center gap-6">
      <a href="/about" class={`text-[10px] font-black uppercase tracking-widest transition-all ${isAbout ? 'text-blueberry-500' : 'text-blueberry-800/40 hover:text-blueberry-900'}`}>Mission</a>
    </div>
  </div>
</nav>

<style>
  a { text-decoration: none; }
</style>
