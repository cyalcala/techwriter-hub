---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const isOpp = currentPath === '/opportunities';
---
<nav class="fixed top-0 left-0 right-0 z-50 transition-colors duration-500 border-b border-white/5 bg-black/60 backdrop-blur-xl">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-white font-black text-sm tracking-tighter hover:scale-105 transition-all">
      <div class="w-6 h-6 bg-blue-600 rounded flex items-center justify-center font-black text-xs">V</div>
      <span>VA.INDEX</span>
    </a>

    <div class="p-1 border bg-zinc-900/50 border-white/5 rounded-2xl flex items-center gap-1">
      <a 
        href="/" 
        class={`px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 relative overflow-hidden group ${isHome ? 'text-blue-500 bg-white/5 shadow-[0_0_20px_-10px_rgba(59,130,246,0.5)]' : 'text-zinc-600 hover:text-zinc-400 hover:bg-white/5'}`}
      >
        <span class="relative z-10 font-black">Agencies</span>
      </a>
      <a 
        href="/opportunities" 
        class={`px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 relative overflow-hidden group ${isOpp ? 'text-blue-500 bg-white/5 shadow-[0_0_20px_-10px_rgba(59,130,246,0.5)]' : 'text-zinc-600 hover:text-zinc-400 hover:bg-white/5'}`}
      >
        <span class="relative z-10 font-black">Feed</span>
      </a>
    </div>
    
    <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 border bg-blue-500/5 border-blue-500/10 rounded-full">
      <div class="pulse-dot"></div>
      <span class="text-[8px] font-black text-blue-500 tracking-[0.2em] uppercase">SYNCING</span>
    </div>
  </div>
</nav>

<style>
  a { text-decoration: none; }
</style>
