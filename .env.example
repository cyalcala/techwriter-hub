# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Inngest (Event orchestration)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Scraper Proxy (Ph-Direct Shield)
VA_PROXY_SECRET=your-proxy-secret
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-id
CLOUDFLARE_API_TOKEN=your-cloudflare-token

# Trigger.dev (Legacy jobs)
TRIGGER_SECRET_KEY=tr_dev_your-secret-key

# AI Intelligence Mesh (Primary)
CEREBRAS_API_KEY=your-cerebras-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# AI Intelligence Mesh (Final Boss)
GEMINI_API_KEY=your-gemini-api-key

# Public Site Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_SITE_URL=https://your-domain.com
